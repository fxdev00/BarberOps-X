pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command: [sleep]
    args: ["9999999"]
    workingDir: /home/jenkins/agent/workspace/${JOB_NAME}
    resources:
      requests:
        ephemeral-storage: "6Gi"
      limits:
        ephemeral-storage: "6Gi"
  - name: tools
    image: alpine:3.20
    command: [cat]
    tty: true
    workingDir: /home/jenkins/agent/workspace/${JOB_NAME}
    securityContext:
      runAsUser: 1000
      runAsGroup: 1000
      fsGroup: 1000
    resources:
      requests:
        ephemeral-storage: "2Gi"
      limits:
        ephemeral-storage: "2Gi"
"""
        }
    }

    environment {
        PROJECT_ID   = "barberops-xx"
        REGION       = "europe-west2"
        REGISTRY     = "${REGION}-docker.pkg.dev/${PROJECT_ID}/barberops"
        IMAGE_TAG    = "${env.GIT_COMMIT[0..7]}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.BRANCH_TAG = env.GIT_BRANCH.replaceAll('/', '-')
                }
            }
        }

        stage('Lint') {
            steps {
                container('tools') {
                    sh '''
                        apk add --no-cache py3-pip git
                        pip install flake8 --quiet --break-system-packages
                        flake8 backend/ \
                            --max-line-length=120 \
                            --exclude=__pycache__
                    '''
                }
            }
        }

        stage('Build Backend') {
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor \
                            --context=${WORKSPACE}/backend \
                            --dockerfile=${WORKSPACE}/backend/Dockerfile \
                            --destination=${REGISTRY}/backend:${IMAGE_TAG} \
                            --destination=${REGISTRY}/backend:${BRANCH_TAG} \
                            --push-retry=3
                    """
                }
            }
        }

        stage('Build Frontend') {
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor \
                            --context=${WORKSPACE}/frontend \
                            --dockerfile=${WORKSPACE}/frontend/Dockerfile \
                            --destination=${REGISTRY}/frontend:${IMAGE_TAG} \
                            --destination=${REGISTRY}/frontend:${BRANCH_TAG} \
                            --push-retry=3
                    """
                }
            }
        }

        stage('Security Scan') {
            steps {
                container('tools') {
                    sh """
                        apk add --no-cache curl
                        curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin
                        trivy image --exit-code 1 --severity HIGH,CRITICAL --ignore-unfixed --no-progress ${REGISTRY}/backend:${IMAGE_TAG}
                        trivy image --exit-code 1 --severity HIGH,CRITICAL --ignore-unfixed --no-progress ${REGISTRY}/frontend:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Update Image Tags in Git') {
            when {
                expression {
                    env.GIT_BRANCH == 'main' || env.GIT_BRANCH == 'origin/main'
                }
            }
            steps {
                container('tools') {
                    withCredentials([usernamePassword(
                        credentialsId: 'github-token', 
                        usernameVariable: 'GIT_USER', 
                        passwordVariable: 'GIT_PAT'
                    )]) {
                        sh '''
                            set -e

                            cd ${WORKSPACE}

                            apk add --no-cache git

                            # Fix git ownership issue
                            git config --global --add safe.directory "${WORKSPACE}"

                            git config user.email "jenkins@barberops.com"
                            git config user.name "Jenkins CI"

                            # Update image tags
                            sed -i "s|image: .*backend:.*|image: ${REGISTRY}/backend:${IMAGE_TAG}|g" k8s/backend/deployment.yaml
                            sed -i "s|image: .*frontend:.*|image: ${REGISTRY}/frontend:${IMAGE_TAG}|g" k8s/frontend/deployment.yaml

                            git add k8s/backend/deployment.yaml k8s/frontend/deployment.yaml

                            if git diff --cached --quiet; then
                                echo "No changes to image tags - skipping commit"
                            else
                                git commit -m "ci: deploy ${IMAGE_TAG} [skip ci]"
                                git push https://${GIT_USER}:${GIT_PAT}@github.com/fxdev00/BarberOps-X.git HEAD:main
                                echo "✅ Image tags updated and pushed successfully"
                            fi
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Build ${IMAGE_TAG} pushed. ArgoCD will deploy within 3 minutes."
        }
        failure {
            echo "Pipeline failed at stage: ${currentBuild.result}"
        }
    }
}